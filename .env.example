# llama-cpp-nvidia-tq environment configuration
# Copy this file to .env and adjust values for your environment.

# Docker image
IMAGE_REGISTRY=192.168.50.11:5000
IMAGE_NAME=mkadrlik/llama-cpp-nvidia-tq
IMAGE_TAG=latest

# Model
MODEL_PATH=/path/to/your/model.gguf
MODEL_MOUNT=/model.gguf

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# TurboQuant cache types
# Options: f16, q8_0, turbo4, turbo3, turbo2
# Recommended: turbo3 for best balance of speed/quality/VRAM
CACHE_TYPE_K=q8_0
CACHE_TYPE_V=turbo3

# GPU layers (-1 = all layers offloaded)
GPU_LAYERS=99

# Thread count (leave empty to auto-detect)
THREADS=

# Context size (default: model's native context length)
CONTEXT_SIZE=

# Additional llama-server arguments (optional)
EXTRA_ARGS=
