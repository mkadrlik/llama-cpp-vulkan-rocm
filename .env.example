###############################################################################
# llama-cpp-vulkan-tq — environment configuration
#
# Copy this file to .env and adjust values for your environment.
#
# NOTE: Vulkan does NOT support TurboQuant. This backend is for speed.
# Use the ROCm backend for TurboQuant KV cache compression.
###############################################################################

# Docker image
IMAGE_REGISTRY=ghcr.io
IMAGE_NAME=mkadrlik/llama-cpp-vulkan-rocm
IMAGE_TAG=latest

# Model
MODEL_PATH=/path/to/your/model.gguf
MODEL_MOUNT=/model.gguf

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# GPU layers (-1 = all layers offloaded)
GPU_LAYERS=99

# Thread count (leave empty to auto-detect)
THREADS=

# Context size (default: model's native context length)
CONTEXT_SIZE=

# Additional llama-server arguments (optional)
# Examples:
#   - Use KV cache offload: -ngl 0 -c 8192 -ctk f16 -ctv f16
#   - Use Flash Attention (default, enabled in compose): -fa on
EXTRA_ARGS=
